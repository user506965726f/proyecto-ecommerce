create database DATAMART_ECOMERCE
go
use DATAMART_ECOMERCE
go	

-- Tabla Dim Tiempo
create table dim_tiempo(
	pk_tiempo int primary key identity,
	fecha date,
	año smallint,
	trimestre smallint,
	mes smallint,
	mes_nombre varchar(20),
	semana smallint,
	dia smallint,
	dia_semana varchar(20)
	)
go
--Tabla Dim Categoria
create table dim_categoria(
	pk_categoria int primary key identity,
	id_categoria int,
	nombre_categoria varchar(50)
	)
go
--Tabla Dim Producto
create table dim_producto(
	pk_producto int primary key identity,
	id_producto int,
	nombre varchar(100),
	descripcion varchar(255)
	)
go
--Tabla Dim Cliente
create table dim_cliente(
	pk_cliente int primary key identity,
	id_cliente int,
	nombre_completo varchar(100),
	ciudad varchar(50),
	estado_cliente varchar(3)
	)
go
--Tabla Dim Pago
create table dim_pago(
	pk_pago int primary key identity,
	id_pago int,
	metodo_pago varchar(50),
	estado_pago varchar(20)
	)
go

--Tabla de los hechos (fact_ventas)
create table fact_ventas(
	pk_venta int primary key identity,
	pk_tiempo int references dim_tiempo(pk_tiempo),
	pk_producto int references dim_producto(pk_producto),
	pk_cliente int references dim_cliente(pk_cliente),
	pk_pago int references dim_pago(pk_pago),
	cantidad int,
	precio_unitario decimal(10,2),
	subtotal_linea decimal(10,2),
	total decimal(10,2)
	)
go

-- 1. Eliminar tabla dim_categoria (si ya existe)
drop table if exists dim_categoria;

-- 2. Recrear dim_producto incluyendo categoría
create table dim_producto(
    pk_producto int primary key identity,
    id_producto int,
    nombre varchar(100),
    descripcion varchar(255),
    id_categoria int,      -- Agregado
    nombre_categoria varchar(50)  -- Agregado
);
go

-- 3. Cargar datos (sin tabla dim_categoria)
insert into dim_producto(id_producto, nombre, descripcion, id_categoria, nombre_categoria)
select 
    p.id_producto,
    p.nombre,
    'Producto de e-commerce' as descripcion,
    c.id_categoria,
    c.nombre as nombre_categoria
from ecommerce.dbo.productos p
join ecommerce.dbo.categorias c on p.id_categoria = c.id_categoria;
go

-- 4. Crear fact_ventas sin conexión a dim_categoria (solo a dim_producto)
create table fact_ventas(
    pk_venta int primary key identity,
    pk_tiempo int references dim_tiempo(pk_tiempo),
    pk_producto int references dim_producto(pk_producto),  -- Aquí ya tienes la categoría
    pk_cliente int references dim_cliente(pk_cliente),
    pk_pago int references dim_pago(pk_pago),
    cantidad int,
    precio_unitario decimal(10,2),
    subtotal_linea decimal(10,2),
    total decimal(10,2)
);
go
