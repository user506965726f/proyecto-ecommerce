--Procedimientos Almacenados
--SP-01 : Registrar pedido
CREATE OR ALTER PROCEDURE sp_registrar_pedido
    @id_cliente INT,
    @fecha_pedido DATE,
    @estado NVARCHAR(20),
    @ciudad_envio NVARCHAR(50)
AS
BEGIN
    INSERT INTO pedidos
    (
        id_cliente,
        fecha_pedido,
        estado,
        ciudad_envio
    )
    VALUES
    (
        @id_cliente,
        @fecha_pedido,
        @estado,
        @ciudad_envio
    );
END;
GO

--SP-02: Consultar cliente
CREATE PROCEDURE sp_historial_cliente
    @id_cliente INT
AS
BEGIN
    SELECT *
    FROM pedidos
    WHERE id_cliente=@id_cliente;
END;
GO
--Prueba
EXEC sp_historial_cliente 1;
--SP-03: Actualizar Stock
CREATE PROCEDURE sp_actualizar_stock
    @id_producto INT,
    @cantidad INT
AS
BEGIN
    UPDATE productos
    SET stock = stock + @cantidad
    WHERE id_producto=@id_producto;
END;
GO
--SP-04: Reporte de Venta Por Categoria
CREATE PROCEDURE sp_reporte_categoria
AS
BEGIN

SELECT
c.nombre Categoria,
SUM(dp.cantidad) CantidadVendida,
SUM(dp.subtotal) TotalVentas
FROM categorias c
INNER JOIN productos p
ON c.id_categoria=p.id_categoria
INNER JOIN detalle_pedidos dp
ON p.id_producto=dp.id_producto
GROUP BY c.nombre;

END;
GO
--SP-05: Cancelar Pedido
CREATE PROCEDURE sp_cancelar_pedido
    @id_pedido INT
AS
BEGIN

UPDATE pedidos
SET estado='Cancelado'
WHERE id_pedido=@id_pedido;

END;
GO

--Funciones
--FN-01: Calcular Descuento
CREATE FUNCTION fn_calcular_descuento
(
 @cantidad INT
)
RETURNS DECIMAL(5,2)
AS
BEGIN

DECLARE @desc DECIMAL(5,2)

SET @desc=
CASE
WHEN @cantidad BETWEEN 3 AND 5 THEN 0.05
WHEN @cantidad BETWEEN 6 AND 10 THEN 0.10
WHEN @cantidad >10 THEN 0.15
ELSE 0
END

RETURN @desc

END
GO
--FN-02: Total Pedido
CREATE FUNCTION fn_total_pedido
(
 @id_pedido INT
)
RETURNS DECIMAL(12,2)
AS
BEGIN

DECLARE @total DECIMAL(12,2)

SELECT @total=SUM(subtotal)
FROM detalle_pedidos
WHERE id_pedido=@id_pedido

RETURN ISNULL(@total,0)

END
GO
--FN-03: Stock Disponible
CREATE FUNCTION fn_stock_producto
(
 @id_producto INT
)
RETURNS INT
AS
BEGIN

DECLARE @stock INT

SELECT @stock=stock
FROM productos
WHERE id_producto=@id_producto

RETURN @stock

END
GO
--FN-04: Cantidad Productos Vendidos
CREATE FUNCTION fn_productos_vendidos
(
 @id_producto INT
)
RETURNS INT
AS
BEGIN

DECLARE @cantidad INT

SELECT @cantidad=SUM(cantidad)
FROM detalle_pedidos
WHERE id_producto=@id_producto

RETURN ISNULL(@cantidad,0)

END
GO
--FN-05: Ingresos Categoria
CREATE FUNCTION fn_ingresos_categoria
(
 @id_categoria INT
)
RETURNS DECIMAL(12,2)
AS
BEGIN

DECLARE @total DECIMAL(12,2)

SELECT @total=SUM(dp.subtotal)
FROM detalle_pedidos dp
INNER JOIN productos p
ON dp.id_producto=p.id_producto
WHERE p.id_categoria=@id_categoria

RETURN ISNULL(@total,0)

END
GO

